# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
RUST_LOG=nodus_core_engine=info,tower_http=info

# ── Stellar Network ───────────────────────────────────────────────────────────
# "mainnet" or "testnet"
STELLAR_NETWORK=testnet

# ── AMM Pool Contract ─────────────────────────────────────────────────────────
# Leave blank to run the engine without pool endpoints (payments still work).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
POOL_CONTRACT_ID=
POOL_TOKEN_0=XLM
POOL_TOKEN_1=USDC

# ── Retry ─────────────────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=200
