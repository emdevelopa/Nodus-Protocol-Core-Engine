# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
RUST_LOG=nodus_core_engine=info,tower_http=info

# ── Stellar Network ───────────────────────────────────────────────────────────
# "mainnet" or "testnet"
STELLAR_NETWORK=testnet

# ── AMM Pool Contract ─────────────────────────────────────────────────────────
# Leave blank to run the engine without pool endpoints (payments still work).
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
POOL_CONTRACT_ID=
POOL_TOKEN_0=XLM
POOL_TOKEN_1=USDC

# ── Retry ─────────────────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
RETRY_INITIAL_DELAY_MS=200

# ── Redis (idempotency) ──────────────────────────────────────────────────────
# Optional. When set, idempotency keys survive engine restarts.
# When unset, keys are stored in memory (lost on restart).
# Keys are stored with the "idem:" prefix (e.g. "idem:pay-xyz-123").
REDIS_URL=redis://127.0.0.1:6379
IDEMPOTENCY_TTL_SECS=86400
